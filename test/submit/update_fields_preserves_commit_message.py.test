from ghstack.test_prelude import *

await init_test()

# Check that we do clobber fields when explicitly asked

await commit("A")
(A,) = await gh_submit("Initial 1")

await git("commit", "--amend", "-m", "Amended " + A.commit_msg)
(A2,) = await gh_submit("Update 1", update_fields=True)

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Amended Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * f5336bd [INITIAL] Initial 1

        Repository state:

            * f5336bd (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Amended Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit A

            * 3cac216 [INITIAL] Initial 1

        Repository state:

            * 3cac216 (gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

assert "Amended" in await git("log", "--format=%B", "-n", "1", "HEAD")

ok()
