from ghstack.test_prelude import *

await init_test()

await commit("A")
(A,) = await gh_submit(
    "Initial commit", reviewer="reviewer1,reviewer2", label="bug,enhancement"
)

# Verify reviewers and labels were added
assert_eq(get_pr_reviewers(500), ["reviewer1", "reviewer2"])
assert_eq(get_pr_labels(500), ["bug", "enhancement"])

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * d6c39c3 [INITIAL] Initial commit

        Repository state:

            * d6c39c3 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial commit
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit A

            * 2c03b2f [INITIAL] Initial commit

        Repository state:

            * 2c03b2f (gh/ezyang/1/head)
            |    [INITIAL] Initial commit
            * 5956f18 (gh/ezyang/1/base)
            |    Initial commit (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
