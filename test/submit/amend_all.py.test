from ghstack.test_prelude import *

await init_test()

await commit("A")
await gh_submit("Initial 1")

await commit("B")
A2, B2 = await gh_submit("Initial 2")

await checkout(A2)
await amend("A3")
await cherry_pick(B2)
await amend("B3")
A3, B3 = await gh_submit("Update A")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 60bc096 Update A
            * 8c7d059 Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * 797401a Update A
            * 0243aa2 Initial 2

        Repository state:

            *   797401a (gh/ezyang/2/next, gh/ezyang/2/head)
            |\\     Update A
            | * 60bc096 (gh/ezyang/1/next, gh/ezyang/1/head)
            | |    Update A
            * | 0243aa2
            |/     Initial 2
            * 8c7d059
            |    Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 3bc91e8 Update A
            * 36fcfdf Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * 4050cf9 Update A
            * ca4399f Initial 2

        Repository state:

            * 3bc91e8 (gh/ezyang/1/head)
            |    Update A
            * 36fcfdf
            |    Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            | *   4050cf9 (gh/ezyang/2/head)
            | |\\     Update A
            | | * 390391f (gh/ezyang/2/base)
            | | |    Update A (base update)
            | * | ca4399f
            | |/     Initial 2
            | * c05297f
            |/     Initial 2 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
