from ghstack.test_prelude import *

await init_test()

await commit("A")
await commit("B")
await commit("C")
A, B, C = await gh_submit("Initial")

# Direct mode NYI for 3-commit partial submit
if not is_direct():
    # Go back to A, amend it, cherry-pick B and C on top
    await checkout(A)
    await amend("A2")
    await cherry_pick(B)
    await cherry_pick(C)

    # Submit only A (bottom), leaving B and C as orphans
    (A2,) = await gh_submit("Update base only", revs=["HEAD~2"], stack=False)

    assert_eq(A.number, A2.number)

    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #502
            * #501
            * __->__ #500

            This is commit A

            * 694bea3 [UPDATE] Update base only
            * 2dad5bb [INITIAL] Initial

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * #502
            * __->__ #501
            * #500

            This is commit B

            * 64921b5 [INITIAL] Initial

        [O] #502 Commit C (gh/ezyang/3/head -> gh/ezyang/3/base)

            Stack:
            * __->__ #502
            * #501
            * #500

            This is commit C

            * 610d342 [INITIAL] Initial

        Repository state:

            * 694bea3 (gh/ezyang/1/head)
            |    [UPDATE] Update base only
            * 2dad5bb
            |    [INITIAL] Initial
            * 4e92121 (gh/ezyang/1/base)
            |    Initial (base update)
            | * 64921b5 (gh/ezyang/2/head)
            | |    [INITIAL] Initial
            | * db684f8 (gh/ezyang/2/base)
            |/     Initial (base update)
            | * 610d342 (gh/ezyang/3/head)
            | |    [INITIAL] Initial
            | * 8fe2454 (gh/ezyang/3/base)
            |/     Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
