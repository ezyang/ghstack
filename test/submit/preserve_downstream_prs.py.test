from ghstack.test_prelude import *

await init_test()

await commit("A")
await commit("B")
A, B = await gh_submit("Initial")

# Now go back to A, amend it, and cherry-pick B on top
await checkout(A)
await amend("A2")
await cherry_pick(B)

# Submit only A (the bottom of the stack), not B
(A2,) = await gh_submit("Update base only", revs=["HEAD~"], stack=False)

assert_eq(A.number, A2.number)

if is_direct():
    pass
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 00b248f [UPDATE] Update base only
            * a25b1bd [INITIAL] Initial

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * daa092a [INITIAL] Initial

        Repository state:

            * 00b248f (gh/ezyang/1/head)
            |    [UPDATE] Update base only
            * a25b1bd
            |    [INITIAL] Initial
            * 13c3cb3 (gh/ezyang/1/base)
            |    Initial (base update)
            | * daa092a (gh/ezyang/2/head)
            | |    [INITIAL] Initial
            | * 8e6f9ba (gh/ezyang/2/base)
            |/     Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
