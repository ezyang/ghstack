from ghstack.test_prelude import *

await init_test()

# This is to test a bug where we decided not to update base,
# but this was wrong

await git("checkout", "-b", "feature")
await commit("A")
await commit("B")
A, B = await gh_submit("Initial 2")

await git("checkout", "main")
await cherry_pick(B)
(B2,) = await gh_submit("Cherry pick")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 045a0a8 [INITIAL] Initial 2

        [O] #501 Commit B (gh/ezyang/2/head -> main)

            This is commit B

            * 09aa552 [UPDATE] Cherry pick
            * 931b284 [INITIAL] Initial 2
            * 045a0a8 [INITIAL] Initial 2

        Repository state:

            * 09aa552 (gh/ezyang/2/next, gh/ezyang/2/head)
            |    [UPDATE] Cherry pick
            * 931b284
            |    [INITIAL] Initial 2
            * 045a0a8 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 2
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 182fa7c [INITIAL] Initial 2

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * 0729b87 [UPDATE] Cherry pick
            * 21a0449 [INITIAL] Initial 2

        Repository state:

            *   0729b87 (gh/ezyang/2/head)
            |\\     [UPDATE] Cherry pick
            | * a8c0a6e (gh/ezyang/2/base)
            | |    Cherry pick (base update)
            * | 21a0449
            |/     [INITIAL] Initial 2
            * c05297f
            |    Initial 2 (base update)
            | * 182fa7c (gh/ezyang/1/head)
            | |    [INITIAL] Initial 2
            | * f081adc (gh/ezyang/1/base)
            |/     Initial 2 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
