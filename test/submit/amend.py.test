from ghstack.test_prelude import *

await init_test()

await commit("A")
(A,) = await gh_submit("Initial 1")

await amend("A2")
(A2,) = await gh_submit("Update A")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 324abac Update A
            * 8c7d059 Initial 1

        Repository state:

            * 324abac (gh/ezyang/1/next, gh/ezyang/1/head)
            |    Update A
            * 8c7d059
            |    Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit A

            * f004e08 Update A
            * 36fcfdf Initial 1

        Repository state:

            * f004e08 (gh/ezyang/1/head)
            |    Update A
            * 36fcfdf
            |    Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
