from ghstack.test_prelude import *

await init_test()

await commit("A")
(A,) = await gh_submit("Initial 1")

await amend("A2")
(A2,) = await gh_submit("Update A")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * d602cd7 [UPDATE] Update A
            * f5336bd [INITIAL] Initial 1

        Repository state:

            * d602cd7 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [UPDATE] Update A
            * f5336bd
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit A

            * 57ec684 [UPDATE] Update A
            * 3cac216 [INITIAL] Initial 1

        Repository state:

            * 57ec684 (gh/ezyang/1/head)
            |    [UPDATE] Update A
            * 3cac216
            |    [INITIAL] Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
