from ghstack.test_prelude import *

await init_test()

# Check that we don't clobber changes to PR description or title

await write_file_and_add("b", "asdf")
await git("commit", "-m", "Commit 1\n\nOriginal message")
tick()
await gh_submit("Initial 1")
tick()

await get_github().apatch(
    "repos/pytorch/pytorch/pulls/500",
    body="""\
Stack:
* **#500 Commit 1**

Directly updated message body""",
    title="Directly updated title",
)

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> main)

            Stack:
            * **#500 Commit 1**

            Directly updated message body

            * 7a0c4fe [INITIAL] Initial 1

        Repository state:

            * 7a0c4fe (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * **#500 Commit 1**

            Directly updated message body

            * 17a07ca [INITIAL] Initial 1

        Repository state:

            * 17a07ca (gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

await write_file_and_add("file1.txt", "A")
await git("commit", "--amend", "--no-edit")
tick()
await gh_submit("Update 1")
tick()

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> main)

            Stack:
            * __->__ #500

            Directly updated message body

            * 0447dbb [UPDATE] Update 1
            * 7a0c4fe [INITIAL] Initial 1

        Repository state:

            * 0447dbb (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [UPDATE] Update 1
            * 7a0c4fe
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            Directly updated message body

            * f902334 [UPDATE] Update 1
            * 17a07ca [INITIAL] Initial 1

        Repository state:

            * f902334 (gh/ezyang/1/head)
            |    [UPDATE] Update 1
            * 17a07ca
            |    [INITIAL] Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
