from ghstack.test_prelude import *

await init_test()

# In some situations, GitHub will replace your newlines with
# \r\n.  Check we handle this correctly.

await write_file_and_add("b", "asdf")
await git("commit", "-m", "Commit 1\n\nOriginal message")
tick()
await gh_submit("Initial 1")
tick()

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit 1 (gh/ezyang/1/head -> main)

            Original message

            * 7a0c4fe [INITIAL] Initial 1

        Repository state:

            * 7a0c4fe (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit 1 (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            Original message

            * 17a07ca [INITIAL] Initial 1

        Repository state:

            * 17a07ca (gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

await get_github().apatch(
    "repos/pytorch/pytorch/pulls/500",
    body="""\
Stack:
* **#500 Commit 1**

Directly updated message body""".replace(
        "\n", "\r\n"
    ),
    title="Directly updated title",
)

await write_file_and_add("file1.txt", "A")
await git("commit", "-m", "Commit 2")
tick()
await gh_submit("Initial 2")
tick()

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> main)

            Stack:
            * #501
            * __->__ #500

            Directly updated message body

            * 7a0c4fe [INITIAL] Initial 1

        [O] #501 Commit 2 (gh/ezyang/2/head -> gh/ezyang/1/head)



            * 77b6028 [INITIAL] Initial 2

        Repository state:

            * 77b6028 (gh/ezyang/2/next, gh/ezyang/2/head)
            |    [INITIAL] Initial 2
            * 7a0c4fe (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            Directly updated message body

            * 17a07ca [INITIAL] Initial 1

        [O] #501 Commit 2 (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500



            * 6f37061 [INITIAL] Initial 2

        Repository state:

            * 6f37061 (gh/ezyang/2/head)
            |    [INITIAL] Initial 2
            * df3e13f (gh/ezyang/2/base)
            |    Initial 2 (base update)
            | * 17a07ca (gh/ezyang/1/head)
            | |    [INITIAL] Initial 1
            | * 5a32949 (gh/ezyang/1/base)
            |/     Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
