from ghstack.test_prelude import *

await init_test()

await commit("AAA")
(A,) = await gh_submit("Initial 1")
assert "AAA" in A.commit_msg
await git("commit", "--amend", "-m", A.commit_msg.replace("AAA", "BBB"))

(A2,) = await gh_submit("Update A", no_skip=True)

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit AAA (gh/ezyang/1/head -> main)

            This is commit AAA

            * 5b2b060 [INITIAL] Initial 1

        Repository state:

            * 5b2b060 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit AAA (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit AAA

            * b407946 [INITIAL] Initial 1

        Repository state:

            * b407946 (gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )

ok()
