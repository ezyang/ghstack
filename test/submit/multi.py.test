from ghstack.test_prelude import *

await commit("A")
await commit("B")
A, B = await gh_submit("Initial 1 and 2")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * a6f543f [INITIAL] Initial 1 and 2

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * e4bfb1e [INITIAL] Initial 1 and 2

        Repository state:

            * e4bfb1e (gh/ezyang/2/next, gh/ezyang/2/head)
            |    [INITIAL] Initial 1 and 2
            * a6f543f (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1 and 2
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * fe11d1d [INITIAL] Initial 1 and 2

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * 5ba095d [INITIAL] Initial 1 and 2

        Repository state:

            * fe11d1d (gh/ezyang/1/head)
            |    [INITIAL] Initial 1 and 2
            * cc79b9e (gh/ezyang/1/base)
            |    Initial 1 and 2 (base update)
            | * 5ba095d (gh/ezyang/2/head)
            | |    [INITIAL] Initial 1 and 2
            | * 954b129 (gh/ezyang/2/base)
            |/     Initial 1 and 2 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
