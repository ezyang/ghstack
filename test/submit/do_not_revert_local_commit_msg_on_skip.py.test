from ghstack.test_prelude import *
import textwrap

await init_test()

await commit("TO_REPLACE")
(A,) = await gh_submit("Initial")
await git("commit", "--amend", "-m", A.commit_msg.replace("TO_REPLACE", "ARGLE"))
(A2,) = await gh_submit("Skip")
if is_direct():
    assert_expected_inline(
        textwrap.indent(await git("show", "-s", "--pretty=%B", "HEAD"), " " * 8),
        """\
        Commit ARGLE

        This is commit ARGLE

        ghstack-source-id: ac00f28640afe01e4299441bb5041cdf06d0b6b4
        ghstack-comment-id: 1500
        Pull-Request: https://github.com/pytorch/pytorch/pull/500""",
    )
else:
    assert_expected_inline(
        textwrap.indent(await git("show", "-s", "--pretty=%B", "HEAD"), " " * 8),
        """\
        Commit ARGLE

        This is commit ARGLE

        ghstack-source-id: ac00f28640afe01e4299441bb5041cdf06d0b6b4
        Pull-Request: https://github.com/pytorch/pytorch/pull/500""",
    )

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit TO_REPLACE (gh/ezyang/1/head -> main)

            This is commit TO_REPLACE

            * 43ce90d Initial

        Repository state:

            * 43ce90d (gh/ezyang/1/next, gh/ezyang/1/head)
            |    Initial
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit TO_REPLACE (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit TO_REPLACE

            * 5bb1f7c Initial

        Repository state:

            * 5bb1f7c (gh/ezyang/1/head)
            |    Initial
            * 11e6d4d (gh/ezyang/1/base)
            |    Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
