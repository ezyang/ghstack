from ghstack.test_prelude import *

await init_test()

await git("checkout", "-b", "feature")

await commit("A")
await commit("B")
A, B = await gh_submit("Initial 2")

await git("checkout", "main")
await commit("M")
await git("push", "origin", "main")

await cherry_pick(B)
await gh_submit("Cherry pick")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 2193fd2 Initial 2

        [O] #501 Commit B (gh/ezyang/2/head -> main)

            This is commit B

            * 6d41420 Cherry pick
            * ce2fa9b Initial 2
            * 2193fd2 Initial 2

        Repository state:

            *   6d41420 (gh/ezyang/2/next, gh/ezyang/2/head)
            |\\     Cherry pick
            | * 7ceeaa9 (HEAD -> main)
            | |    Commit M
            * | ce2fa9b
            | |    Initial 2
            * | 2193fd2 (gh/ezyang/1/next, gh/ezyang/1/head)
            |/     Initial 2
            * dc8bfe4
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 12d35d5 Initial 2

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * 80be1e3 Cherry pick
            * ca4399f Initial 2

        Repository state:

            *   80be1e3 (gh/ezyang/2/head)
            |\\     Cherry pick
            | *   8f5c855 (gh/ezyang/2/base)
            | |\\     Cherry pick (base update)
            | | * 7ceeaa9 (HEAD -> main)
            | | |    Commit M
            * | | ca4399f
            |/ /     Initial 2
            * / c05297f
            |/     Initial 2 (base update)
            | * 12d35d5 (gh/ezyang/1/head)
            | |    Initial 2
            | * f081adc (gh/ezyang/1/base)
            |/     Initial 2 (base update)
            * dc8bfe4
                 Initial commit
        """
    )
