from ghstack.test_prelude import *

await init_test()

await git("checkout", "-b", "feature")

await commit("A")
await commit("B")
A, B = await gh_submit("Initial 2")

await git("checkout", "main")
await commit("M")
await git("push", "origin", "main")

await cherry_pick(B)
await gh_submit("Cherry pick")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 045a0a8 [INITIAL] Initial 2

        [O] #501 Commit B (gh/ezyang/2/head -> main)

            This is commit B

            * 1fd1fb7 [UPDATE] Cherry pick
            * 931b284 [INITIAL] Initial 2
            * 045a0a8 [INITIAL] Initial 2

        Repository state:

            *   1fd1fb7 (gh/ezyang/2/next, gh/ezyang/2/head)
            |\\     [UPDATE] Cherry pick
            | * 7ceeaa9 (HEAD -> main)
            | |    Commit M
            * | 931b284
            | |    [INITIAL] Initial 2
            * | 045a0a8 (gh/ezyang/1/next, gh/ezyang/1/head)
            |/     [INITIAL] Initial 2
            * dc8bfe4
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 182fa7c [INITIAL] Initial 2

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * e06d56e [UPDATE] Cherry pick
            * 21a0449 [INITIAL] Initial 2

        Repository state:

            *   e06d56e (gh/ezyang/2/head)
            |\\     [UPDATE] Cherry pick
            | *   8f5c855 (gh/ezyang/2/base)
            | |\\     Cherry pick (base update)
            | | * 7ceeaa9 (HEAD -> main)
            | | |    Commit M
            * | | 21a0449
            |/ /     [INITIAL] Initial 2
            * / c05297f
            |/     Initial 2 (base update)
            | * 182fa7c (gh/ezyang/1/head)
            | |    [INITIAL] Initial 2
            | * f081adc (gh/ezyang/1/base)
            |/     Initial 2 (base update)
            * dc8bfe4
                 Initial commit
        """
    )
