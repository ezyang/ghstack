from ghstack.test_prelude import *

init_test()

# Create initial commit on a feature branch and submit
git("checkout", "-b", "feature")
commit("A")
(A,) = gh_submit("Initial commit")

# Add some commits to master and push them
git("checkout", "master")
commit("Base1")
commit("Base2")
git("push", "origin", "master")

# Scenario: Both remote and local rebase onto master, but local also has additional changes
# This simulates a realistic divergence where two sources updated the same PR

# First, checkout the feature branch, rebase onto master, and submit
# (this becomes the "remote" version that someone else pushed)
git("checkout", "feature")
git("rebase", "origin/master")
(A2,) = gh_submit("Rebase onto master")

# Now, go back to the original commit and create a different version
# Reset to original A, rebase onto master, AND add local changes
git("reset", "--hard", A.orig)
git("rebase", "origin/master")
# Add local changes on top of the rebased commit
write_file_and_add("local_change.txt", "This is a local change")
git("commit", "--amend", "--no-edit", tick=True)

# Now try to submit - this should fail with the divergence error
# The key point: both versions rebased onto master (so they both have the same base),
# but the local version has extra changes that the remote doesn't have
assert_expected_raises_inline(
    RuntimeError,
    lambda: gh_submit("Update with local changes"),
    """\
Someone else updated this PR. To merge your changes with theirs:

  git fetch origin
  git merge origin/gh/ezyang/1/head
  # resolve conflicts, then squash to a single commit:
  git reset --soft origin/master
  git commit -c origin/gh/ezyang/1/orig

Or use --force to overwrite their changes.""",
)
