from ghstack.test_prelude import *

await init_test()

# make release branch
await git("branch", "release", "main")

# diverge release and regular branch
await git("checkout", "main")
await commit("M")
await git("push", "origin", "main")

await git("checkout", "release")
await commit("R")
await git("push", "origin", "release")

# make commit on release branch
await commit("A")

# use non-standard base
await gh_submit("Initial 1", base="release")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> release)

            This is commit A

            * 503142b Initial 1

        Repository state:

            * 503142b (gh/ezyang/1/next, gh/ezyang/1/head)
            |    Initial 1
            * 9ac8806 (release)
            |    Commit R
            * dc8bfe4
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit A

            * 19687ac Initial 1

        Repository state:

            * 19687ac (gh/ezyang/1/head)
            |    Initial 1
            * 7687c36 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * 9ac8806 (release)
            |    Commit R
            * dc8bfe4
                 Initial commit
        """
    )

ok()
