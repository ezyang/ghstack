from ghstack.test_prelude import *

await init_test()

# TODO: NYI
if not is_direct():
    await commit("A")
    await commit("B")
    A, B = await gh_submit("Initial")

    await checkout(A)
    await amend("A2")
    await cherry_pick(B)
    (B2,) = await gh_submit("Update head only", revs=["HEAD"], stack=False)

    assert_eq(B.number, B2.number)

    ok()
