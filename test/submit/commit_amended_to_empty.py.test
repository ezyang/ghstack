from ghstack.test_prelude import *

await init_test()

await write_file_and_add("bar", "baz")
await git("commit", "-m", "Commit 1\n\nThis is my first commit")

(A,) = await gh_submit("Initial")

await git("rm", "bar")
await git("commit", "--amend", "--allow-empty", "--no-edit")
tick()

# TODO: direct NYI
if not is_direct():
    await gh_submit("Update")

    await assert_github_state(
        """\
        [O] #500 Commit 1 (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is my first commit

            * 4dc7499 [INITIAL] Initial

        Repository state:

            * 4dc7499 (gh/ezyang/1/head)
            |    [INITIAL] Initial
            * ce88e73 (gh/ezyang/1/base)
            |    Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
