from ghstack.test_prelude import *

await init_test()

await commit("A")
await commit("B")
A, B = await gh_submit("Initial")

await checkout(GitCommitHash("HEAD~~"))
await cherry_pick(B)
await cherry_pick(A)
B2, A2 = await gh_submit("Reorder")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/2/head)

            This is commit A

            * 3859ef3 [UPDATE] Reorder

        [O] #501 Commit B (gh/ezyang/2/head -> main)

            This is commit B

            * f189bab [UPDATE] Reorder
            * b81bed9 [INITIAL] Initial
            * 67f4095 [INITIAL] Initial

        Repository state:

            *   3859ef3 (gh/ezyang/1/next, gh/ezyang/1/head)
            |\\     [UPDATE] Reorder
            | * f189bab (gh/ezyang/2/next, gh/ezyang/2/head)
            | |    [UPDATE] Reorder
            | * b81bed9
            |/     [INITIAL] Initial
            * 67f4095
            |    [INITIAL] Initial
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500
            * #501

            This is commit A

            * 53c9bf8 [UPDATE] Reorder
            * a25b1bd [INITIAL] Initial

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * #500
            * __->__ #501

            This is commit B

            * e2ff35d [UPDATE] Reorder
            * daa092a [INITIAL] Initial

        Repository state:

            *   53c9bf8 (gh/ezyang/1/head)
            |\\     [UPDATE] Reorder
            | * d4668d1 (gh/ezyang/1/base)
            | |    Reorder (base update)
            * | a25b1bd
            |/     [INITIAL] Initial
            * 13c3cb3
            |    Initial (base update)
            | *   e2ff35d (gh/ezyang/2/head)
            | |\\     [UPDATE] Reorder
            | | * d082148 (gh/ezyang/2/base)
            | | |    Reorder (base update)
            | * | daa092a
            | |/     [INITIAL] Initial
            | * 8e6f9ba
            |/     Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
