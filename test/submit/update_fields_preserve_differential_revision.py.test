from ghstack.test_prelude import *

await init_test()

# Check that Differential Revision is preserved

await commit("A")
await gh_submit("Initial 1")

body = """\n
Directly updated message body

Differential Revision: [D14778507](https://our.internmc.facebook.com/intern/diff/D14778507)
"""
await get_github().apatch(
    "repos/pytorch/pytorch/pulls/500", body=body, title="Directly updated title"
)

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> main)



            Directly updated message body

            Differential Revision: [D14778507](https://our.internmc.facebook.com/intern/diff/D14778507)


            * 8c7d059 Initial 1

        Repository state:

            * 8c7d059 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Directly updated title (gh/ezyang/1/head -> gh/ezyang/1/base)



            Directly updated message body

            Differential Revision: [D14778507](https://our.internmc.facebook.com/intern/diff/D14778507)


            * 36fcfdf Initial 1

        Repository state:

            * 36fcfdf (gh/ezyang/1/head)
            |    Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

await gh_submit("Update 1", update_fields=True)

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            Differential Revision: [D14778507](https://our.internmc.facebook.com/intern/diff/D14778507)

            * 8c7d059 Initial 1

        Repository state:

            * 8c7d059 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            This is commit A

            Differential Revision: [D14778507](https://our.internmc.facebook.com/intern/diff/D14778507)

            * 36fcfdf Initial 1

        Repository state:

            * 36fcfdf (gh/ezyang/1/head)
            |    Initial 1
            * 5a32949 (gh/ezyang/1/base)
            |    Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
