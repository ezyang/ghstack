from ghstack.test_prelude import *

await init_test()

await commit("A")
(A,) = await gh_submit("Initial 1")

await commit("B")
A2, B2 = await gh_submit("Initial 2")

await amend("B2")
A3, B3 = await gh_submit("Update A")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * f5336bd [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * 4ffe97d [UPDATE] Update A
            * e5cbc93 [INITIAL] Initial 2

        Repository state:

            * 4ffe97d (gh/ezyang/2/next, gh/ezyang/2/head)
            |    [UPDATE] Update A
            * e5cbc93
            |    [INITIAL] Initial 2
            * f5336bd (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 3cac216 [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * adb9847 [UPDATE] Update A
            * 21a0449 [INITIAL] Initial 2

        Repository state:

            * adb9847 (gh/ezyang/2/head)
            |    [UPDATE] Update A
            * 21a0449
            |    [INITIAL] Initial 2
            * c05297f (gh/ezyang/2/base)
            |    Initial 2 (base update)
            | * 3cac216 (gh/ezyang/1/head)
            | |    [INITIAL] Initial 1
            | * 5a32949 (gh/ezyang/1/base)
            |/     Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
