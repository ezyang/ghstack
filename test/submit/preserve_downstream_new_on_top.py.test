from ghstack.test_prelude import *

await init_test()

await commit("A")
await commit("B")
await commit("D")
A, B, D = await gh_submit("Initial")

# Go back to B, amend it, and add a new commit C on top (dropping D)
await checkout(B)
await amend("B2")
await commit("C")

# Submit B and C. C is new (no old stack text), so the orphan logic
# must skip past C and find B's old stack text to discover D as an
# orphan above the submitted PRs.
await gh_submit("Add C", revs=["HEAD~", "HEAD"], stack=False)

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * bf9f464 [INITIAL] Initial

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * f7b1305 [UPDATE] Add C
            * afa9bba [INITIAL] Initial

        [O] #502 Commit D (gh/ezyang/3/head -> gh/ezyang/2/head)

            This is commit D

            * ec92743 [INITIAL] Initial

        [O] #503 Commit C (gh/ezyang/4/head -> gh/ezyang/2/head)

            This is commit C

            * ba38a96 [INITIAL] Add C

        Repository state:

            * ba38a96 (gh/ezyang/4/next, gh/ezyang/4/head)
            |    [INITIAL] Add C
            * f7b1305 (gh/ezyang/2/next, gh/ezyang/2/head)
            |    [UPDATE] Add C
            | * ec92743 (gh/ezyang/3/next, gh/ezyang/3/head)
            |/     [INITIAL] Initial
            * afa9bba
            |    [INITIAL] Initial
            * bf9f464 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #502
            * #501
            * __->__ #500

            This is commit A

            * 2dad5bb [INITIAL] Initial

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * #502
            * __->__ #501
            * #503
            * #500

            This is commit B

            * db22764 [UPDATE] Add C
            * 64921b5 [INITIAL] Initial

        [O] #502 Commit D (gh/ezyang/3/head -> gh/ezyang/3/base)

            Stack:
            * __->__ #502
            * #501
            * #500

            This is commit D

            * 00b8df2 [INITIAL] Initial

        [O] #503 Commit C (gh/ezyang/4/head -> gh/ezyang/4/base)

            Stack:
            * #502
            * #501
            * __->__ #503
            * #500

            This is commit C

            * b715271 [INITIAL] Add C

        Repository state:

            * db22764 (gh/ezyang/2/head)
            |    [UPDATE] Add C
            * 64921b5
            |    [INITIAL] Initial
            * db684f8 (gh/ezyang/2/base)
            |    Initial (base update)
            | * b715271 (gh/ezyang/4/head)
            | |    [INITIAL] Add C
            | * f7775f1 (gh/ezyang/4/base)
            |/     Add C (base update)
            | * 2dad5bb (gh/ezyang/1/head)
            | |    [INITIAL] Initial
            | * 4e92121 (gh/ezyang/1/base)
            |/     Initial (base update)
            | * 00b8df2 (gh/ezyang/3/head)
            | |    [INITIAL] Initial
            | * 8fe2454 (gh/ezyang/3/base)
            |/     Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
