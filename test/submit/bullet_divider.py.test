from ghstack.test_prelude import *

await init_test()

await write_file_and_add("file1.txt", "A")
await git(
    "commit",
    "-m",
    """This is my commit

* It starts with a fabulous
* Bullet list""",
)
tick()
await gh_submit("Initial")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 This is my commit (gh/ezyang/1/head -> main)

            * It starts with a fabulous
            * Bullet list

            * ae6e7a9 [INITIAL] Initial

        Repository state:

            * ae6e7a9 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 This is my commit (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * __->__ #500

            ----

            * It starts with a fabulous
            * Bullet list

            * c4c128f [INITIAL] Initial

        Repository state:

            * c4c128f (gh/ezyang/1/head)
            |    [INITIAL] Initial
            * 11e6d4d (gh/ezyang/1/base)
            |    Initial (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )

ok()
