from ghstack.test_prelude import *

await init_test()

await commit("A")
(A,) = await gh_submit("Initial 1")
await commit("B")
A2, B2 = await gh_submit("Initial 2")

await checkout(A2)
await amend("A3")
(A3,) = await gh_submit("Update A")

await cherry_pick(B2)
A4, B4 = await gh_submit("Update B")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 94ef46e [UPDATE] Update A
            * f5336bd [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * f39afb8 [UPDATE] Update B
            * e5cbc93 [INITIAL] Initial 2

        Repository state:

            *   f39afb8 (gh/ezyang/2/next, gh/ezyang/2/head)
            |\\     [UPDATE] Update B
            | * 94ef46e (gh/ezyang/1/next, gh/ezyang/1/head)
            | |    [UPDATE] Update A
            * | e5cbc93
            |/     [INITIAL] Initial 2
            * f5336bd
            |    [INITIAL] Initial 1
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * 4542840 [UPDATE] Update A
            * 3cac216 [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * db3c74d [UPDATE] Update B
            * 21a0449 [INITIAL] Initial 2

        Repository state:

            *   db3c74d (gh/ezyang/2/head)
            |\\     [UPDATE] Update B
            | * 26f7790 (gh/ezyang/2/base)
            | |    Update B (base update)
            * | 21a0449
            |/     [INITIAL] Initial 2
            * c05297f
            |    Initial 2 (base update)
            | * 4542840 (gh/ezyang/1/head)
            | |    [UPDATE] Update A
            | * 3cac216
            | |    [INITIAL] Initial 1
            | * 5a32949 (gh/ezyang/1/base)
            |/     Initial 1 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """,
    )
