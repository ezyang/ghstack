from ghstack.test_prelude import *

await git("checkout", "-b", "feature")

await commit("A")
(A1,) = await gh_submit("Initial 1")
await commit("B")
A2, B2 = await gh_submit("Initial 2")

await git("checkout", "main")
await commit("M")
await git("push", "origin", "main")

await git("checkout", "feature")
await git("rebase", "origin/main")

await gh_submit("Rebase")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * d56d5d4 [UPDATE] Rebase
            * f5336bd [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * 85aaf57 [UPDATE] Rebase
            * e5cbc93 [INITIAL] Initial 2

        Repository state:

            *   85aaf57 (gh/ezyang/2/next, gh/ezyang/2/head)
            |\\     [UPDATE] Rebase
            | *   d56d5d4 (gh/ezyang/1/next, gh/ezyang/1/head)
            | |\\     [UPDATE] Rebase
            | | * 7ceeaa9 (HEAD -> main)
            | | |    Commit M
            * | | e5cbc93
            |/ /     [INITIAL] Initial 2
            * / f5336bd
            |/     [INITIAL] Initial 1
            * dc8bfe4
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * f2d9f95 [UPDATE] Rebase
            * 3cac216 [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * 6703ff2 [UPDATE] Rebase
            * 21a0449 [INITIAL] Initial 2

        Repository state:

            *   f2d9f95 (gh/ezyang/1/head)
            |\\     [UPDATE] Rebase
            | *   107d5ce (gh/ezyang/1/base)
            | |\\     Rebase (base update)
            * | | 3cac216
            |/ /     [INITIAL] Initial 1
            * | 5a32949
            | |    Initial 1 (base update)
            | | *   6703ff2 (gh/ezyang/2/head)
            | | |\\     [UPDATE] Rebase
            | | | *   d80b302 (gh/ezyang/2/base)
            | | | |\\     Rebase (base update)
            | | |_|/
            | |/| |
            | * | | 7ceeaa9 (HEAD -> main)
            |/ / /     Commit M
            | * / 21a0449
            | |/     [INITIAL] Initial 2
            | * c05297f
            |/     Initial 2 (base update)
            * dc8bfe4
                 Initial commit
        """
    )
