from ghstack.test_prelude import *

await init_test()

await commit("A")
await commit("B")
await gh_submit("Initial 1")

# Unlink
await gh_unlink()

await gh_submit("Initial 2")

if is_direct():
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> main)

            This is commit A

            * 36e17d6 [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/1/head)

            This is commit B

            * 9528b2a [INITIAL] Initial 1

        [O] #502 Commit A (gh/ezyang/3/head -> main)

            This is commit A




            * 045a0a8 [INITIAL] Initial 2

        [O] #503 Commit B (gh/ezyang/4/head -> gh/ezyang/3/head)

            This is commit B




            * 931b284 [INITIAL] Initial 2

        Repository state:

            * 9528b2a (gh/ezyang/2/next, gh/ezyang/2/head)
            |    [INITIAL] Initial 1
            * 36e17d6 (gh/ezyang/1/next, gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            | * 931b284 (gh/ezyang/4/next, gh/ezyang/4/head)
            | |    [INITIAL] Initial 2
            | * 045a0a8 (gh/ezyang/3/next, gh/ezyang/3/head)
            |/     [INITIAL] Initial 2
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
else:
    await assert_github_state(
        """\
        [O] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

            * b1aaa28 [INITIAL] Initial 1

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501
            * #500

            This is commit B

            * 6c70328 [INITIAL] Initial 1

        [O] #502 Commit A (gh/ezyang/3/head -> gh/ezyang/3/base)

            Stack:
            * #503
            * __->__ #502

            This is commit A

            * 182fa7c [INITIAL] Initial 2

        [O] #503 Commit B (gh/ezyang/4/head -> gh/ezyang/4/base)

            Stack:
            * __->__ #503
            * #502

            This is commit B

            * 21a0449 [INITIAL] Initial 2

        Repository state:

            * b1aaa28 (gh/ezyang/1/head)
            |    [INITIAL] Initial 1
            * 73a877d (gh/ezyang/1/base)
            |    Initial 1 (base update)
            | * 6c70328 (gh/ezyang/2/head)
            | |    [INITIAL] Initial 1
            | * 9d4a439 (gh/ezyang/2/base)
            |/     Initial 1 (base update)
            | * 182fa7c (gh/ezyang/3/head)
            | |    [INITIAL] Initial 2
            | * f081adc (gh/ezyang/3/base)
            |/     Initial 2 (base update)
            | * 21a0449 (gh/ezyang/4/head)
            | |    [INITIAL] Initial 2
            | * c05297f (gh/ezyang/4/base)
            |/     Initial 2 (base update)
            * dc8bfe4 (HEAD -> main)
                 Initial commit
        """
    )
