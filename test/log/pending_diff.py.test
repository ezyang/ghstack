from ghstack.test_prelude import *

init_test()

# Create a PR, then make local changes that haven't been pushed yet.
# ghstack log should show those local-vs-remote changes as a synthesized
# "Local pending changes" commit at the top.
commit("A")
gh_submit("Initial commit")

# Make a local change but don't submit
write_file_and_add("A.txt", "pending local change")
git("commit", "--amend", "--no-edit", tick=True)

with captured_output() as (out, _):
    gh_log()
output = out.getvalue()

assert "Local pending changes (not yet submitted)" in output, output
assert "Initial commit" in output, output

# With -p, the synthesized commit's diff shows the pending content
with captured_output() as (out, _):
    gh_log(args=["-p"])
output = out.getvalue()
assert "pending local change" in output, output

ok()
