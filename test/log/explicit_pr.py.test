from ghstack.test_prelude import *

await init_test()

# Submit a PR, then switch HEAD away.  Explicit-PR mode should still work
# and should NOT include any pending-changes commit (local HEAD is irrelevant).
await commit("A")
(A,) = await gh_submit("Initial commit")

await git("checkout", "main")

with captured_output() as (out, _):
    await gh_log(
        pull_request=f"https://github.com/pytorch/pytorch/pull/{A.number}",
        args=["--format=%s"],
    )
assert_expected_inline(
    out.getvalue(),
    """\
[INITIAL] Initial commit
""",
)

ok()
