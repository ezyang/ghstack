from ghstack.test_prelude import *

await init_test()

# Create a PR to checkout
await commit("A")
(A,) = await gh_submit("Initial commit")

# Move to main and create another commit
await git("checkout", "main")
await commit("B")

# Verify we're on main with commit B
current_log = await git("log", "--oneline", "-n", "1")
assert "Commit B" in current_log

# Checkout the PR
await gh_checkout(f"https://github.com/pytorch/pytorch/pull/{A.number}")

# After checkout, we should be on the PR commit
current_log = await git("log", "--oneline", "-n", "1")
assert "Commit A" in current_log

ok()
