from ghstack.test_prelude import *

await init_test()

await commit("A")
await commit("B")
(diff1, diff2) = await gh_submit("Initial 1")
assert diff1 is not None
assert diff2 is not None

# setup an upstream commit, so the land isn't just trivial
await git("reset", "--hard", "origin/main")
await commit("U")
await git("push")

# land first pr
await gh_land(diff1.pr_url)

# go back to stack
await git("checkout", "gh/ezyang/2/orig")

# update second pr
await amend("B2")

# try to push
await assert_expected_raises_inline(
    RuntimeError,
    lambda: gh_submit("Run 2"),
    """Cannot ghstack a stack with closed PR #500 whose branch was deleted.  If you were just trying to update a later PR in the stack, `git rebase` and try again.  Otherwise, you may have been trying to update a PR that was already closed. To disassociate your update from the old PR and open a new PR, run `ghstack unlink`, `git rebase` and then try again.""",
)

# show the remediation works
await git("rebase", "origin/main")
await gh_submit("Run 3")

if is_direct():
    await assert_github_state("""""")
else:
    await assert_github_state(
        """\
        [X] #500 Commit A (gh/ezyang/1/head -> gh/ezyang/1/base)

            Stack:
            * #501
            * __->__ #500

            This is commit A

              (omitted)

        [O] #501 Commit B (gh/ezyang/2/head -> gh/ezyang/2/base)

            Stack:
            * __->__ #501

            This is commit B

            * 87c9ccd Run 3
            * 16e1e12 Initial 1

        Repository state:

            *   87c9ccd (gh/ezyang/2/head)
            |\\     Run 3
            | *   a800ca6 (gh/ezyang/2/base)
            | |\\     Run 3 (base update)
            | | * 70eb094 (HEAD -> main)
            | | |    Commit A (#500)
            | | * 7f0288c
            | | |    Commit U
            * | | 16e1e12
            |/ /     Initial 1
            * / 9d4a439
            |/     Initial 1 (base update)
            * dc8bfe4
                 Initial commit
        """
    )

ok()
