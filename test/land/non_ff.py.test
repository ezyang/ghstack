from ghstack.test_prelude import *

await init_test()

await commit("A")
(diff,) = await gh_submit("Initial")
assert diff is not None
pr_url = diff.pr_url

await git("reset", "--hard", "origin/main")
await commit("U")
await git("push")

await git("checkout", "gh/ezyang/1/orig")
await gh_land(pr_url)

assert_expected_inline(
    await get_upstream_sh().agit("log", "--oneline", "main"),
    """\
8b61aeb Commit A (#500)
38808c0 Commit U
dc8bfe4 Initial commit""",
)
