from ghstack.test_prelude import *

await init_test()

# make a stack
await commit("A")
(diff1,) = await gh_submit("Initial 1")
assert diff1 is not None

# land first pr
await gh_land(diff1.pr_url)

# make another stack
await commit("B")
(diff2,) = await gh_submit("Second 2")
assert diff2 is not None

# check the head number was reused
assert_eq(diff1.ghnum, diff2.ghnum)

# refuse to reland first pr
await assert_expected_raises_inline(
    RuntimeError,
    lambda: gh_land(diff1.pr_url),
    """PR is already closed, cannot land it!""",
)
